\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ktu_dissertation_style}[2026/04/21 v2.0 KTU thesis style]

% -------------------- Core packages & fonts --------------------
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{mathptmx}
\RequirePackage{graphicx}
\RequirePackage{csquotes}
\RequirePackage{textcomp}
\RequirePackage{xcolor}
\definecolor{darkgreen}{RGB}{0,100,0}

% -------------------- Page geometry --------------------
\RequirePackage[
  paperwidth=170mm,
  paperheight=240mm,
  left=20mm,
  right=18mm,
  top=18mm,
  bottom=18mm
]{geometry}

% -------------------- Page style --------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[RO,LE]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[RO,LE]{\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

% -------------------- Text flow & spacing --------------------
\RequirePackage[none]{hyphenat}
\RequirePackage{ragged2e}
\RequirePackage{setspace}
\singlespacing
\emergencystretch=3.5em
\setlength{\parindent}{0.9cm}
\setlength{\parskip}{0pt}
\RequirePackage{indentfirst}

% -------------------- Sectioning --------------------
\RequirePackage{titlesec}
\titlespacing*{\section}{0pt}{1.5ex plus 1ex minus .2ex}{0.5ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.5ex plus .2ex}

\titleformat{\section}
  {\normalfont\fontsize{10}{8}\bfseries}{\thesection.\quad}{0em}{}
\titleformat{\subsection}
  {\normalfont\fontsize{10}{8}\bfseries}{\thesubsection.\quad}{0em}{}
\titleformat{\subsubsection}
  {\normalfont\fontsize{10}{8}\bfseries}{\thesubsubsection.\quad}{0em}{}

% Start each section on a new page
\titleclass{\section}{top}
\newcommand\sectionbreak{\clearpage}

% -------------------- Lists --------------------
\RequirePackage{enumitem}
\setlist[enumerate]{itemsep=0pt, parsep=0pt, topsep=0pt, partopsep=0pt, leftmargin=*}
\setlist[description]{itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, leftmargin=0pt}
\setlist[itemize]{itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, leftmargin=0pt}

% -------------------- Captions & counters --------------------
\RequirePackage[
  font={stretch=1.15},
  tableposition=top,
  figureposition=bottom,
  labelfont=bf
]{caption}
\captionsetup[table]{format=hang, justification=justified, singlelinecheck=false}
\captionsetup[figure]{justification=centering, singlelinecheck=false}

\RequirePackage{chngcntr}
% Keep figure/table numbering global to match current main.tex behavior.
\counterwithout{table}{section}
\counterwithout{figure}{section}
\counterwithin{equation}{section}

% -------------------- Hyperlinks --------------------
\RequirePackage{hyperref}
\hypersetup{colorlinks=false}

% -------------------- Math, plots & graphics --------------------
\RequirePackage{amsmath}
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\usetikzlibrary{decorations.pathreplacing,positioning,arrows.meta,fit,backgrounds,calc}
\tikzset{
  >=Latex,
  layer/.style={draw, rounded corners=2pt, thick, align=center, fill=gray!5, inner sep=6pt},
  note/.style={draw, rounded corners=2pt, align=left, fill=yellow!10, inner sep=4pt},
  shapeLbl/.style={font=\small\ttfamily, align=center, text=black!80},
  tinyLbl/.style={font=\scriptsize\ttfamily, text=black!70},
  pipe/.style={-Latex, thick},
}

% -------------------- Tables & floats --------------------
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{lscape}
\RequirePackage{array}
\RequirePackage{float}
\RequirePackage{multirow}
\RequirePackage{multicol}
\RequirePackage{subcaption}
\newcolumntype{R}{>{\raggedright\arraybackslash}p{\linewidth}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}p{#1}}
\newcolumntype{L}[1]{>{\raggedleft\arraybackslash}p{#1}}

% -------------------- Other utilities --------------------
\RequirePackage{lastpage}
\RequirePackage{etoolbox}
\RequirePackage{soul}
\RequirePackage[normalem]{ulem}
\RequirePackage{needspace}
\RequirePackage{wasysym}
% -------------------- Title capitalization --------------------
\RequirePackage{mfirstuc}
\MFUnocap{the}
\MFUnocap{and}

% -------------------- Language support --------------------
\makeatletter
\@ifpackageloaded{babel}{}{%
  \RequirePackage[main=english,lithuanian]{babel}%
}
\makeatother

% -------------------- TOC, LoF & LoT formatting --------------------
\RequirePackage{tocloft}

% TOC structure
\setlength{\cftsecindent}{0pt}
\setlength{\cftsubsecindent}{0pt}
\setlength{\cftsubsubsecindent}{0pt}
\setlength{\cftsecnumwidth}{2.5em}
\setlength{\cftsubsecnumwidth}{3.3em}
\setlength{\cftsubsubsecnumwidth}{4.1em}

\renewcommand{\cftsecfont}{\fontsize{10.5}{12}\selectfont\bfseries}
\renewcommand{\cftsecpagefont}{\fontsize{11}{14}\selectfont\bfseries}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cftsubsecleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cftsubsubsecleader}{\cftdotfill{\cftdotsep}}

\makeatletter
\renewcommand{\l@section}[2]{%
  \ifnum\c@tocdepth>\z@
    \vskip \cftbeforesecskip
    {\cftsecfont\noindent #1\nobreak\cftsecleader\hbox to\@pnumwidth{\hss\cftsecpagefont #2}\par}%
  \fi
}
\makeatother

\setlength{\cftbeforesecskip}{0pt}
\setlength{\cftbeforesubsecskip}{0pt}
\setlength{\cftbeforesubsubsecskip}{0pt}

% LoF/LoT title fonts and entry indents
\renewcommand\cftloftitlefont{\normalfont\fontsize{10}{8}\bfseries}
\renewcommand\cftlottitlefont{\normalfont\fontsize{10}{8}\bfseries}
\renewcommand\cfttoctitlefont{\normalfont\fontsize{10}{8}\bfseries}
\setlength{\cftfigindent}{0pt}
\setlength{\cfttabindent}{0pt}

% Helpers to suppress extra vertical gaps in LoF/LoT
\makeatletter
\newcommand{\listoffiguresnospace}{%
  \begingroup
    \let\addvspace\@gobble
    \listoffigures
  \endgroup
}
\newcommand{\listoftablesnospace}{%
  \begingroup
    \let\addvspace\@gobble
    \listoftables
  \endgroup
}
\makeatother

% Lithuanian caption label order: "<number> <name>"
\DeclareCaptionLabelFormat{ltrev}{#2~#1}

% English hooks
\addto\captionsenglish{%
  \renewcommand{\figurename}{Fig.}%
  \renewcommand{\tablename}{Table}%
  \renewcommand{\listfigurename}{\MakeUppercase{List of Figures}}%
  \renewcommand{\listtablename}{\MakeUppercase{List of Tables}}%
  \captionsetup{labelformat=simple, labelsep=period, format=hang}%
  \captionsetup[table]{format=hang, justification=justified, singlelinecheck=false}%
  \captionsetup[figure]{justification=centering, singlelinecheck=false}%
  \renewcommand{\cftfigpresnum}{\bfseries\figurename~}%
  \renewcommand{\cftfigaftersnum}{.}%
  \settowidth{\cftfignumwidth}{\bfseries\figurename~99.99.\,}%
  \renewcommand{\cfttabpresnum}{\bfseries\tablename~}%
  \renewcommand{\cfttabaftersnum}{.}%
  \settowidth{\cfttabnumwidth}{\bfseries\tablename~99.99.\,}%
}

% Lithuanian hooks
\makeatletter
\@ifundefined{captionslithuanian}{}{%
  \addto\captionslithuanian{%
    \renewcommand{\figurename}{pav.}%
    \renewcommand{\tablename}{lentel\.{e}.}%
    \renewcommand{\listfigurename}{\MakeUppercase{Paveikslų sąrašas}}%
    \renewcommand{\listtablename}{\MakeUppercase{Lentelių sąrašas}}%
    \captionsetup{labelformat=ltrev, labelsep=space, format=hang}%
    \captionsetup[table]{format=hang, justification=justified, singlelinecheck=false}%
    \renewcommand{\cftfigpresnum}{\bfseries}%
    \renewcommand{\cftfigaftersnum}{\space\bfseries\figurename\hspace{1.2em}}%
    \renewcommand{\cfttabpresnum}{\bfseries}%
    \renewcommand{\cfttabaftersnum}{\space\bfseries\tablename\hspace{1.2em}}%
    \settowidth{\cftfignumwidth}{\bfseries 99.99\space\tablename~\quad}%
    \settowidth{\cfttabnumwidth}{\bfseries 99.99\space\tablename~\quad}%
  }%
}
\makeatother

% -------------------- Glossary formatting helpers --------------------
% Keep package loading, glossary definitions, and \makeglossaries in main.tex.
\newcommand{\GlossSemicolon}{%
  \renewcommand*{\glossentry}[2]{%
    \item[\glsentryitem{##1}\glstarget{##1}{\glossentryname{##1}}] -- \glossentrydesc{##1};%
  }%
}

\newcommand{\GlossPeriod}{%
  \renewcommand*{\glossentry}[2]{%
    \item[\glsentryitem{##1}\glstarget{##1}{\glossentryname{##1}}] -- \glossentrydesc{##1}.%
  }%
}

% -------------------- End of package --------------------
\endinput
